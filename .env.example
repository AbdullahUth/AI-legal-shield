# ---------------------------------------------------------------------------
# AI Legal Shield - environment configuration EXAMPLE
# ---------------------------------------------------------------------------
# Copy this file to ".env" and fill in real values locally.
# NEVER commit the real .env file or the real API keys to git.
# ---------------------------------------------------------------------------

# Which provider to use: openrouter | gemini | local | mock
LLM_PROVIDER=openrouter

# PRESENTATION PROVIDER (final hackathon demo) - put the REAL key only in .env
OPENROUTER_API_KEY=put_real_presentation_key_here
OPENROUTER_MODEL=openai/gpt-4o-mini

# TEST PROVIDER (development only - can be removed later)
GEMINI_API_KEY=put_test_gemini_key_here
GEMINI_MODEL=gemini-1.5-flash

# Local OpenAI-compatible API (Podman AI Lab / Ollama / LM Studio)
LOCAL_LLM_BASE_URL=http://localhost:11434/v1
LOCAL_LLM_MODEL=local_model_name

# Optional plain OpenAI key
OPENAI_API_KEY=optional_openai_key

# Set to true to force mock mode (no tokens spent, full pipeline still runs)
MOCK_MODE=false
